<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{{ case_id }} - DFIR Report</title>
  <style>
    body { font-family: Arial, Helvetica, sans-serif; margin: 32px; color: #111; }
    h1, h2, h3 { margin-bottom: 8px; }
    .meta { margin-bottom: 24px; }
    .section { margin-top: 28px; page-break-inside: avoid; }
    .card { border: 1px solid #ddd; border-radius: 8px; padding: 14px; margin-bottom: 12px; }
    .sev-high { border-left: 8px solid #a00; }
    .sev-medium { border-left: 8px solid #c96a00; }
    .sev-low { border-left: 8px solid #5078a0; }
    table { border-collapse: collapse; width: 100%; font-size: 13px; }
    th, td { border: 1px solid #ddd; padding: 6px; text-align: left; vertical-align: top; }
    th { background: #f5f5f5; }
    pre { background: #f7f7f7; padding: 12px; white-space: pre-wrap; border-radius: 6px; }
    .small { font-size: 12px; color: #555; }
  </style>
</head>
<body>
  <h1>DFIR Triage Report</h1>
  <div class="meta">
    <div><strong>Case ID:</strong> {{ case_id }}</div>
    <div><strong>Hostname:</strong> {{ hostname }}</div>
    <div><strong>Profile:</strong> {{ profile }}</div>
    <div><strong>Collected At (UTC):</strong> {{ collected_at_utc }}</div>
  </div>

  <div id="executive-summary" class="section">
    <h2>Executive Summary</h2>
    <pre>{{ executive_summary_markdown }}</pre>
  </div>

  <div id="findings" class="section">
    <h2>Findings</h2>
    {% if findings %}
      {% for finding in findings %}
        <div class="card sev-{{ finding.severity }}">
          <h3>{{ finding.severity|upper }} — {{ finding.title }}</h3>
          <p>{{ finding.description }}</p>
          {% if finding.evidence %}
          <ul>
            {% for item in finding.evidence %}
            <li>{{ item }}</li>
            {% endfor %}
          </ul>
          {% endif %}
        </div>
      {% endfor %}
    {% else %}
      <div class="card">No heuristic findings were generated.</div>
    {% endif %}
  </div>

  <div id="system" class="section">
    <h2>System Context</h2>
    <div class="card">
      <table>
        <tbody>
          {% for key, value in summary.items() %}
          <tr><th>{{ key }}</th><td>{{ value }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <div id="defender" class="section">
    <h2>Microsoft Defender</h2>
    <div class="card">
      <h3>Status</h3>
      <table>
        <tbody>
          {% for key, value in defender_status.items() %}
          <tr><th>{{ key }}</th><td>{{ value }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <div class="card">
      <h3>Detections</h3>
      {% if defender_threats %}
      <table>
        <thead>
          <tr>
            <th>Threat</th>
            <th>Resources / Path</th>
            <th>Detection Time</th>
          </tr>
        </thead>
        <tbody>
          {% for item in defender_threats %}
          <tr>
            <td>{{ item.get("ThreatName") or item.get("ThreatID") }}</td>
            <td>{{ item.get("Resources") or item.get("Path") }}</td>
            <td>{{ item.get("InitialDetectionTime") }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p>No Defender detections were parsed from the collected JSON.</p>
      {% endif %}
    </div>
  </div>

  <div id="persistence" class="section">
    <h2>Persistence Review</h2>
    <div class="card">
      <h3>Scheduled Tasks</h3>
      <table>
        <thead>
          <tr><th>Task</th><th>State</th><th>Actions</th></tr>
        </thead>
        <tbody>
          {% for row in tasks[:100] %}
          <tr>
            <td>{{ row.get("TaskPath", "") }}{{ row.get("TaskName", "") }}</td>
            <td>{{ row.get("State", "") }}</td>
            <td>{{ row.get("Actions", "") }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <div class="card">
      <h3>Run Keys</h3>
      <table>
        <thead>
          <tr><th>Hive</th><th>Registry Path</th><th>Value Name</th><th>Value Data</th></tr>
        </thead>
        <tbody>
          {% for row in run_keys[:100] %}
          <tr>
            <td>{{ row.get("Hive", "") }}</td>
            <td>{{ row.get("RegistryPath", "") }}</td>
            <td>{{ row.get("ValueName", "") }}</td>
            <td>{{ row.get("ValueData", "") }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <div class="card">
      <h3>Services</h3>
      <table>
        <thead>
          <tr><th>Name</th><th>State</th><th>Start Mode</th><th>Path</th></tr>
        </thead>
        <tbody>
          {% for row in services[:100] %}
          <tr>
            <td>{{ row.get("Name", "") }}</td>
            <td>{{ row.get("State", "") }}</td>
            <td>{{ row.get("StartMode", "") }}</td>
            <td>{{ row.get("PathName", "") or row.get("ExecutablePath", "") }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <div id="network" class="section">
    <h2>Network Review</h2>
    <div class="card">
      <h3>TCP Listeners</h3>
      <table>
        <thead>
          <tr><th>Local Address</th><th>Local Port</th><th>Owning PID</th><th>Creation Time</th></tr>
        </thead>
        <tbody>
          {% for row in tcp_listeners[:150] %}
          <tr>
            <td>{{ row.get("LocalAddress", "") }}</td>
            <td>{{ row.get("LocalPort", "") }}</td>
            <td>{{ row.get("OwningProcess", "") }}</td>
            <td>{{ row.get("CreationTime", "") }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  <p class="small">Generated by windows-dfir-evidence-ecosystem.</p>
</body>
</html>
